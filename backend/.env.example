# Copy to .env for local development. On Render, set these as dashboard
# environment variables instead -- do not commit a real .env file.

GEMINI_API_KEY=your-gemini-api-key-here

# Comma-separated list of allowed frontend origins (Vercel domain + localhost)
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

GEN_MODEL=gemini-2.5-flash

RAG_TOP_K=5
RAG_CONTEXT_DOCS=3
RAG_CONTEXT_CHARS=500

MAX_QUESTION_LENGTH=2000
MAX_UPLOAD_BYTES=8388608
