# MediLens Environment Configuration
# Copy to .env and modify as needed

# ========================
# Python API Configuration
# ========================

# Flask Environment
FLASK_ENV=production
FLASK_DEBUG=0
FLASK_APP=api.py

# GPU Configuration
USE_CUDA=1
GPU_MEMORY_FRACTION=0.85
MAX_BATCH_SIZE=1

# Model Configuration
NER_MODEL=dmis-lab/biobert-base-cased-v1.1
EMBEDDER_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/qnli-minilm-l6-mean-tokens

# RAG Configuration
RAG_TOP_K=3
RAG_INDEX_PATH=medilens_rag/pubmed_index.faiss
RAG_TEXTS_PATH=medilens_rag/texts.json

# API Ports
PYTHON_API_PORT=5001
PYTHON_API_HOST=0.0.0.0

# ========================
# Node.js Backend Configuration
# ========================

# Express Environment
NODE_ENV=production
DEBUG=0

# API Ports
BACKEND_PORT=5000
BACKEND_HOST=0.0.0.0

# Python API Connection
PYTHON_API_URL=http://localhost:5001/api/ai

# Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=52428800  # 50MB in bytes
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif

# ========================
# Frontend Configuration
# ========================

# Vite Config
VITE_API_URL=http://localhost:5000/api

# Build
VITE_ENVIRONMENT=development

# ========================
# Logging Configuration
# ========================

LOG_LEVEL=INFO
LOG_FILE=logs/medilens.log
LOG_MAX_SIZE=10485760  # 10MB

# ========================
# Optional: Database (Future)
# ========================

# DATABASE_URL=postgresql://user:password@localhost/medilens
# DB_DEBUG=0

# ========================
# Optional: Error Reporting (Future)
# ========================

# SENTRY_DSN=
# ERROR_REPORTING_ENABLED=0

# ========================
# Performance Tuning
# ========================

# Cache Configuration
CACHE_EMBEDDINGS=1
EMBEDDINGS_CACHE_DIR=.cache/embeddings

# Cleanup Interval (seconds)
CLEANUP_INTERVAL=300  # 5 minutes

# Memory Limits
MAX_QUERY_LENGTH=1000
FAISS_CACHE_SIZE=1000
